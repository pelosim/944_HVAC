# ── Dependencies (huge, auto-installed by npm) ──
dashboard/node_modules/

# ── Build output (auto-generated by npm run build) ──
dashboard/build/

# ── Runtime state (device-specific, not code) ──
hvac_state.json

# ── Python cache ──
__pycache__/
*.pyc
*.pyo

# ── OS junk ──
.DS_Store
Thumbs.db

# ── Editor files ──
*.swp
*~
.vscode/

# ── Logs ──
*.log
